SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DATABASE_URL=postgres://platform:platform@localhost:5432/incident_tracker
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=incidents@example.com
EMAIL_HOST_PASSWORD=secret
DEFAULT_FROM_EMAIL=Platform Incident Tracker <incidents@example.com>
PLATFORM_TEAM_EMAIL=platform@example.com

# Frontend (used in email links)
FRONTEND_BASE_URL=http://localhost:3000

# Slack
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_PLATFORM_INCIDENTS_CHANNEL=#platform-incidents

# Sentry (leave blank to disable)
SENTRY_DSN=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
